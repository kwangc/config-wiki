{
  "name": "config-wiki-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "copy-wiki": "node scripts/copy-wiki.js",
    "dev": "npm run copy-wiki && astro dev",
    "build": "npm run copy-wiki && astro build && npx pagefind --site dist && cp -r dist/pagefind public/pagefind",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.0",
    "astro": "^4.16.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "pagefind": "^1.4.0",
    "sharp": "^0.33.5"
  }
}
