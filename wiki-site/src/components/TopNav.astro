---
import type { Locale } from '../data/i18n';
import { i18n } from '../data/i18n';
import { getWikiNav } from '../data/wikiNav';
import Search from './Search.astro';

interface Props {
  currentPath: string;
  locale?: Locale;
  /** sidebar: 왼쪽 목차 토글 | dropdown: News/About 에서 빠른 메뉴 */
  menuMode?: 'sidebar' | 'dropdown';
}
const { currentPath, locale = 'en', menuMode = 'sidebar' } = Astro.props;
const sidebarLabel = locale === 'ko' ? '목차 열기·닫기' : 'Toggle table of contents';
const quickLabel = locale === 'ko' ? '위키 빠른 이동' : 'Wiki quick menu';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const path = currentPath.replace(base, '') || '/';
const isNews = new RegExp(`^/${locale}/news(/|$)`).test(path);
const isAboutMe = new RegExp(`^/${locale}/about(/|$)`).test(path);
const isWiki = !isNews && !isAboutMe;
const prefix = `${base}/${locale}`;
const t = i18n[locale]?.nav ?? i18n.en.nav;
const currentLabel = locale === 'en' ? 'ENG' : 'KOR';
const pathForLocale = (l: Locale) => path.replace(new RegExp(`^/${locale}(/|$)`), `/${l}$1`);
const hrefEn = pathForLocale('en') ? `${base}${pathForLocale('en')}` : `${base}/en/`;
const hrefKo = pathForLocale('ko') ? `${base}${pathForLocale('ko')}` : `${base}/ko/`;
const wikiNav = getWikiNav(locale, base);
---

<header class="topnav">
  <div class="topnav-left">
    <div class:list={['topnav-menu-wrap', { 'topnav-menu-wrap--dropdown': menuMode === 'dropdown' }]}>
      {menuMode === 'sidebar' ? (
        <button
          type="button"
          class="topnav-menu"
          id="wiki-sidebar-toggle"
          aria-label={sidebarLabel}
          title={sidebarLabel}
          aria-expanded="true"
          aria-controls="wiki-sidebar-shell"
        >
          <span class="topnav-menu-bars" aria-hidden="true"></span>
        </button>
      ) : (
        <>
          <button
            type="button"
            class="topnav-menu"
            id="wiki-quick-trigger"
            aria-label={quickLabel}
            title={quickLabel}
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="wiki-quick-panel"
          >
            <span class="topnav-menu-bars" aria-hidden="true"></span>
          </button>
          <div id="wiki-quick-panel" class="topnav-quick-panel" hidden role="menu" aria-label={quickLabel}>
            {wikiNav.map((item) =>
              item.children ? (
                <div class="topnav-quick-group">
                  <div class="topnav-quick-group-title">{item.label}</div>
                  {item.children.map((child) => (
                    <a href={child.href} class="topnav-quick-link" role="menuitem">{child.label}</a>
                  ))}
                </div>
              ) : (
                <a href={item.href} class="topnav-quick-link topnav-quick-link--flat" role="menuitem">{item.label}</a>
              ),
            )}
          </div>
        </>
      )}
    </div>
    <a href={prefix + '/'} class="topnav-brand">
      <img
        src={`${base}/images/config-logo.png`}
        alt=""
        width="28"
        height="28"
        class="topnav-logo-img"
        decoding="async"
      />
      <span class="topnav-logo-text">Config Wiki</span>
    </a>
    <Search locale={locale} />
  </div>
  <nav class="topnav-links">
    <a href={prefix + '/'} class:list={['topnav-link', { 'is-active': isWiki }]}>{t.wiki}</a>
    <a href={prefix + '/news/'} class:list={['topnav-link', { 'is-active': isNews }]}>{t.news}</a>
    <a href={prefix + '/about/'} class:list={['topnav-link', { 'is-active': isAboutMe }]}>{t.aboutMe}</a>
    <div class="topnav-lang-wrap">
      <button type="button" class="topnav-lang-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Select language" id="lang-trigger">
        <span class="topnav-lang-current">{currentLabel}</span>
        <svg class="topnav-lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg>
      </button>
      <div class="topnav-lang-dropdown" id="lang-dropdown" role="listbox" aria-label="Language" hidden>
        <a href={hrefEn} role="option" class:list={['topnav-lang-option', { 'is-current': locale === 'en' }]} aria-selected={locale === 'en'}>ENG</a>
        <a href={hrefKo} role="option" class:list={['topnav-lang-option', { 'is-current': locale === 'ko' }]} aria-selected={locale === 'ko'}>KOR</a>
      </div>
    </div>
    <div class="topnav-theme-wrap">
      <button
        type="button"
        class="topnav-lang-trigger topnav-theme-trigger"
        id="theme-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-label={t.themeSelect}
        title={t.themeSelect}
      >
        <span class="topnav-theme-current is-mode-system" id="theme-current-icon" aria-hidden="true">
          <svg class="topnav-theme-svg topnav-theme-svg--light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
          <svg class="topnav-theme-svg topnav-theme-svg--dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
          <svg class="topnav-theme-svg topnav-theme-svg--system" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
        </span>
        <svg class="topnav-lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 4l4 4 4-4"/></svg>
      </button>
      <div class="topnav-lang-dropdown topnav-theme-dropdown" id="theme-dropdown" role="listbox" aria-label={t.themeSelect} hidden>
        <button type="button" role="option" class="topnav-lang-option topnav-theme-option" data-theme-mode="light" aria-label={t.themeLightLabel} title={t.themeLightLabel}>
          <svg class="topnav-theme-icon-inline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
        </button>
        <button type="button" role="option" class="topnav-lang-option topnav-theme-option" data-theme-mode="dark" aria-label={t.themeDarkLabel} title={t.themeDarkLabel}>
          <svg class="topnav-theme-icon-inline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
        <button type="button" role="option" class="topnav-lang-option topnav-theme-option" data-theme-mode="system" aria-label={t.themeSystemLabel} title={t.themeSystemLabel}>
          <svg class="topnav-theme-icon-inline" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- 모바일 전용: 햄버거로 열리는 전체 메뉴 드로어 -->
<div id="topnav-drawer" class="topnav-drawer" aria-hidden="true">
  <div class="topnav-drawer-backdrop" id="topnav-drawer-backdrop"></div>
  <div class="topnav-drawer-panel">
    <div class="topnav-drawer-header">
      <span class="topnav-drawer-title">{t.drawerTitle}</span>
      <button type="button" class="topnav-drawer-close" id="topnav-drawer-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="topnav-drawer-nav">
      <a href={prefix + '/'} class:list={['topnav-drawer-link', { 'is-active': isWiki }]}>{t.wiki}</a>
      <a href={prefix + '/news/'} class:list={['topnav-drawer-link', { 'is-active': isNews }]}>{t.news}</a>
      <a href={prefix + '/about/'} class:list={['topnav-drawer-link', { 'is-active': isAboutMe }]}>{t.aboutMe}</a>
    </nav>
    <div class="topnav-drawer-divider"></div>
    <div class="topnav-drawer-wiki">
      {wikiNav.map((item) =>
        item.children ? (
          <div class="topnav-drawer-group">
            <div class="topnav-drawer-group-title">{item.label}</div>
            {item.children.map((child) => {
              const subId = child.id ?? child.label.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
              return child.children ? (
                <details class="topnav-drawer-subgroup" id={`topnav-drawer-${subId}`} data-nav-id={subId}>
                  <summary class="topnav-drawer-subgroup-title">
                    <span>{child.label}</span>
                    <span class="topnav-drawer-chevron" aria-hidden="true">▾</span>
                  </summary>
                  <div class="topnav-drawer-subgroup-body">
                    {child.children.map((grand) => (
                      <a href={grand.href} class="topnav-drawer-wiki-link topnav-drawer-wiki-link--deep">{grand.label}</a>
                    ))}
                  </div>
                </details>
              ) : (
                <a href={child.href} class="topnav-drawer-wiki-link">{child.label}</a>
              );
            })}
          </div>
        ) : (
          <a href={item.href} class="topnav-drawer-wiki-link topnav-drawer-wiki-link--flat">{item.label}</a>
        ),
      )}
    </div>
    <div class="topnav-drawer-footer">
      <span class="topnav-drawer-footer-row">
        <a href={hrefEn} class:list={['topnav-drawer-lang', { 'is-current': locale === 'en' }]}>ENG</a>
        <span class="topnav-drawer-lang-sep">|</span>
        <a href={hrefKo} class:list={['topnav-drawer-lang', { 'is-current': locale === 'ko' }]}>KOR</a>
      </span>
      <span class="topnav-drawer-theme-block" role="group" aria-label={t.themeSelect}>
        <button type="button" class="topnav-drawer-theme topnav-drawer-theme--icononly" data-theme-set="light" aria-label={t.themeLightLabel} title={t.themeLightLabel}>
          <svg class="topnav-theme-icon-inline" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
        </button>
        <button type="button" class="topnav-drawer-theme topnav-drawer-theme--icononly" data-theme-set="dark" aria-label={t.themeDarkLabel} title={t.themeDarkLabel}>
          <svg class="topnav-theme-icon-inline" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
        <button type="button" class="topnav-drawer-theme topnav-drawer-theme--icononly" data-theme-set="system" aria-label={t.themeSystemLabel} title={t.themeSystemLabel}>
          <svg class="topnav-theme-icon-inline" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
        </button>
      </span>
    </div>
  </div>
</div>

<!-- 모바일 전용: 우측 하단 플로팅 햄버거 버튼 (기존 드로어와 동일 동작) -->
<button
  type="button"
  id="topnav-fab"
  class="topnav-fab"
  aria-label={sidebarLabel}
  title={sidebarLabel}
>
  <span class="topnav-fab-icon" aria-hidden="true"></span>
</button>

<script>
  (function () {
    function run() {
      var MOBILE = '(max-width: 768px)';
      var langTrigger = document.getElementById('lang-trigger');
      var langDropdown = document.getElementById('lang-dropdown');
      var quickTrigger = document.getElementById('wiki-quick-trigger');
      var quickPanel = document.getElementById('wiki-quick-panel');
      var drawer = document.getElementById('topnav-drawer');
      var drawerBackdrop = document.getElementById('topnav-drawer-backdrop');
      var drawerClose = document.getElementById('topnav-drawer-close');
      var layout = document.getElementById('wiki-layout');
      var sidebarShell = document.getElementById('wiki-sidebar-shell');
      var sidebarToggle = document.getElementById('wiki-sidebar-toggle');
      var menuBtn = document.querySelector('.topnav-menu-wrap .topnav-menu');
      var fabBtn = document.getElementById('topnav-fab');
      var themeTrigger = document.getElementById('theme-trigger');
      var themeDropdown = document.getElementById('theme-dropdown');
      var THEME_KEY = 'wiki-theme';

      function readStoredMode() {
        try {
          var t = localStorage.getItem(THEME_KEY);
          if (t === 'light' || t === 'dark' || t === 'system') return t;
        } catch (_) {}
        return null;
      }
      function fromMq() {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      function storedOrSystem() {
        var m = readStoredMode();
        return m === 'light' || m === 'dark' || m === 'system' ? m : 'system';
      }
      function resolvedTheme() {
        var m = readStoredMode();
        if (m === 'light' || m === 'dark') return m;
        return fromMq();
      }
      function applyDomResolved(resolved) {
        if (resolved === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else document.documentElement.removeAttribute('data-theme');
      }
      function wikiSetMode(mode) {
        if (mode !== 'light' && mode !== 'dark' && mode !== 'system') return;
        try {
          localStorage.setItem(THEME_KEY, mode);
        } catch (_) {}
        applyDomResolved(resolvedTheme());
        wikiSyncThemeUi();
        try {
          window.dispatchEvent(
            new CustomEvent('wiki-theme-changed', {
              detail: { mode: mode, resolved: resolvedTheme(), origin: 'user' },
            }),
          );
        } catch (_) {}
      }
      function wikiSyncThemeUi() {
        var stored = storedOrSystem();
        var curIcon = document.getElementById('theme-current-icon');
        if (curIcon) {
          curIcon.classList.remove('is-mode-light', 'is-mode-dark', 'is-mode-system');
          if (stored === 'light') curIcon.classList.add('is-mode-light');
          else if (stored === 'dark') curIcon.classList.add('is-mode-dark');
          else curIcon.classList.add('is-mode-system');
        }
        document.querySelectorAll('.topnav-theme-option[data-theme-mode]').forEach(function (btn) {
          var m = btn.getAttribute('data-theme-mode');
          var isSel = m === stored;
          btn.classList.toggle('is-current', isSel);
          btn.setAttribute('aria-selected', isSel ? 'true' : 'false');
        });
        document.querySelectorAll('.topnav-drawer-theme[data-theme-set]').forEach(function (btn) {
          var m = btn.getAttribute('data-theme-set');
          btn.classList.toggle('is-current', m === stored);
        });
      }

      function closeTheme() {
        if (!themeDropdown || !themeTrigger) return;
        themeDropdown.setAttribute('hidden', '');
        themeTrigger.setAttribute('aria-expanded', 'false');
        document.removeEventListener('click', closeThemeOutside);
      }
      function closeThemeOutside(e) {
        var t = e.target;
        if (themeDropdown && !themeDropdown.contains(t) && themeTrigger && !themeTrigger.contains(t)) closeTheme();
      }
      function openTheme() {
        if (!themeDropdown || !themeTrigger) return;
        closeLang();
        if (quickPanel && !quickPanel.hasAttribute('hidden')) {
          quickPanel.setAttribute('hidden', '');
          if (quickTrigger) quickTrigger.setAttribute('aria-expanded', 'false');
        }
        themeDropdown.removeAttribute('hidden');
        themeTrigger.setAttribute('aria-expanded', 'true');
        document.addEventListener('click', closeThemeOutside);
      }

      if (themeTrigger && themeDropdown) {
        themeTrigger.addEventListener('click', function (e) {
          e.stopPropagation();
          if (isMobile()) {
            e.preventDefault();
            if (drawer) openDrawer();
            return;
          }
          if (themeDropdown.hasAttribute('hidden')) openTheme();
          else closeTheme();
        });
        themeDropdown.querySelectorAll('.topnav-theme-option[data-theme-mode]').forEach(function (btn) {
          btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var m = btn.getAttribute('data-theme-mode');
            if (m === 'light' || m === 'dark' || m === 'system') wikiSetMode(m);
            closeTheme();
          });
        });
      }
      document.querySelectorAll('.topnav-drawer-theme[data-theme-set]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          var m = btn.getAttribute('data-theme-set');
          if (m === 'light' || m === 'dark' || m === 'system') wikiSetMode(m);
        });
      });
      wikiSyncThemeUi();
      window.addEventListener('wiki-theme-changed', function () {
        wikiSyncThemeUi();
      });

      function isMobile() {
        return window.matchMedia(MOBILE).matches;
      }

    function closeDrawer() {
      if (!drawer) return;
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      document.removeEventListener('click', closeDrawerOutside);
    }
    function syncDrawerNavFromStorage() {
      if (!drawer) return;
      try {
        drawer.querySelectorAll('.topnav-drawer-subgroup[data-nav-id]').forEach(function (el) {
          var id = el.getAttribute('data-nav-id');
          if (!id) return;
          var key = 'wiki-nav-' + id + '-open';
          var saved = localStorage.getItem(key);
          if (saved === '0') el.removeAttribute('open');
          else if (saved === '1') el.setAttribute('open', '');
        });
      } catch (_) {}
    }
    function openDrawer() {
      if (!drawer) return;
      closeTheme();
      if (langDropdown && !langDropdown.hasAttribute('hidden')) {
        langDropdown.setAttribute('hidden', '');
        if (langTrigger) langTrigger.setAttribute('aria-expanded', 'false');
      }
      if (quickPanel && !quickPanel.hasAttribute('hidden')) {
        quickPanel.setAttribute('hidden', '');
        if (quickTrigger) quickTrigger.setAttribute('aria-expanded', 'false');
      }
      syncDrawerNavFromStorage();
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      document.addEventListener('click', closeDrawerOutside);
    }
    function closeDrawerOutside(e) {
      var t = e.target;
      if (drawer && drawer.contains(t) && !drawerBackdrop.contains(t) && !drawerClose.contains(t)) return;
      closeDrawer();
    }
    function syncSidebarNavFromEvent(id, open) {
      var el = document.querySelector('.nav-subgroup[data-nav-id="' + id + '"]');
      if (el) {
        if (open) el.setAttribute('open', '');
        else el.removeAttribute('open');
      }
    }
    function syncDrawerNavFromEvent(id, open) {
      if (!drawer) return;
      var el = drawer.querySelector('.topnav-drawer-subgroup[data-nav-id="' + id + '"]');
      if (el) {
        if (open) el.setAttribute('open', '');
        else el.removeAttribute('open');
      }
    }
    window.addEventListener('wiki-nav-toggle', function (e) {
      var id = e.detail && e.detail.id;
      var open = e.detail && e.detail.open;
      if (id == null || open === undefined) return;
      syncSidebarNavFromEvent(id, open);
      syncDrawerNavFromEvent(id, open);
    });
    if (drawerBackdrop) drawerBackdrop.addEventListener('click', closeDrawer);
    if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
    if (drawer) {
      drawer.querySelectorAll('a[href]').forEach(function (a) {
        a.addEventListener('click', closeDrawer);
      });
      drawer.querySelectorAll('.topnav-drawer-subgroup[data-nav-id]').forEach(function (el) {
        var id = el.getAttribute('data-nav-id');
        if (!id) return;
        var key = 'wiki-nav-' + id + '-open';
        try {
          var saved = localStorage.getItem(key);
          if (saved === '0') el.removeAttribute('open');
          else if (saved === '1') el.setAttribute('open', '');
        } catch (_) {}
        el.addEventListener('toggle', function () {
          try {
            localStorage.setItem(key, el.open ? '1' : '0');
            window.dispatchEvent(new CustomEvent('wiki-nav-toggle', { detail: { id: id, open: el.open } }));
          } catch (_) {}
        });
      });
    }

    function setSidebarCollapsed(on) {
      if (!layout || !sidebarShell || !sidebarToggle) return;
      layout.classList.toggle('wiki-layout--sidebar-collapsed', Boolean(on));
      sidebarToggle.setAttribute('aria-expanded', on ? 'false' : 'true');
      try { localStorage.setItem('wiki-sidebar-collapsed', on ? '1' : '0'); } catch (_) {}
    }
    if (sidebarShell && sidebarToggle) {
      try {
        if (localStorage.getItem('wiki-sidebar-collapsed') === '1') setSidebarCollapsed(true);
      } catch (_) {}
      sidebarToggle.addEventListener('click', function (e) {
        if (isMobile()) {
          e.preventDefault();
          e.stopPropagation();
          if (drawer) openDrawer();
          return;
        }
        setSidebarCollapsed(!layout.classList.contains('wiki-layout--sidebar-collapsed'));
      });
    }

    if (quickTrigger && quickPanel) {
      quickTrigger.addEventListener('click', function (e) {
        if (isMobile()) {
          e.preventDefault();
          e.stopPropagation();
          if (drawer) openDrawer();
          return;
        }
        if (langDropdown && !langDropdown.hasAttribute('hidden')) {
          langDropdown.setAttribute('hidden', '');
          if (langTrigger) langTrigger.setAttribute('aria-expanded', 'false');
        }
        closeTheme();
        if (quickPanel.hasAttribute('hidden')) {
          quickPanel.removeAttribute('hidden');
          quickTrigger.setAttribute('aria-expanded', 'true');
          document.addEventListener('click', closeQuickOutside);
        } else {
          quickPanel.setAttribute('hidden', '');
          quickTrigger.setAttribute('aria-expanded', 'false');
          document.removeEventListener('click', closeQuickOutside);
        }
      });
    }

    function closeQuickOutside(e) {
      var t = e.target;
      if (quickPanel && !quickPanel.contains(t) && quickTrigger && !quickTrigger.contains(t)) {
        quickPanel.setAttribute('hidden', '');
        if (quickTrigger) quickTrigger.setAttribute('aria-expanded', 'false');
        document.removeEventListener('click', closeQuickOutside);
      }
    }
    if (quickTrigger && quickPanel) {
      quickPanel.querySelectorAll('a[href]').forEach(function (a) {
        a.addEventListener('click', function () {
          quickPanel.setAttribute('hidden', '');
          if (quickTrigger) quickTrigger.setAttribute('aria-expanded', 'false');
          document.removeEventListener('click', closeQuickOutside);
        });
      });
    }

    function closeLang() {
      if (!langDropdown || !langTrigger) return;
      langDropdown.setAttribute('hidden', '');
      langTrigger.setAttribute('aria-expanded', 'false');
      document.removeEventListener('click', closeLangOutside);
    }
    function openLang() {
      if (!langDropdown || !langTrigger) return;
      closeTheme();
      if (quickPanel && !quickPanel.hasAttribute('hidden')) {
        quickPanel.setAttribute('hidden', '');
        if (quickTrigger) quickTrigger.setAttribute('aria-expanded', 'false');
      }
      langDropdown.removeAttribute('hidden');
      langTrigger.setAttribute('aria-expanded', 'true');
      document.addEventListener('click', closeLangOutside);
    }
    function closeLangOutside(e) {
      var t = e.target;
      if (langDropdown && !langDropdown.contains(t) && langTrigger && !langTrigger.contains(t)) closeLang();
    }
    if (langTrigger && langDropdown) {
      langTrigger.addEventListener('click', function (e) {
        e.stopPropagation();
        if (isMobile()) {
          e.preventDefault();
          if (drawer) openDrawer();
          return;
        }
        if (langDropdown.hasAttribute('hidden')) openLang();
        else closeLang();
      });
    }

    if (menuBtn && drawer) {
      menuBtn.addEventListener('click', function (e) {
        if (isMobile()) {
          e.preventDefault();
          e.stopPropagation();
          openDrawer();
        }
      });
    }

    if (fabBtn && drawer) {
      fabBtn.addEventListener('click', function (e) {
        if (!isMobile()) return;
        e.preventDefault();
        e.stopPropagation();
        openDrawer();
      });
    }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();
</script>

