---
import type { Locale } from '../data/i18n';
import { getWikiNav } from '../data/wikiNav';

interface Props {
  currentPath: string;
  locale?: Locale;
}
const { currentPath, locale = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const wikiNav = getWikiNav(locale, base);

function isActive(href: string): boolean {
  const path = currentPath.replace(base, '') || '/';
  const linkPath = href.replace(base, '');
  const pathNorm = path.replace(/\/$/, '') || '/';
  const linkNorm = linkPath.replace(/\/$/, '') || '/';
  if (linkNorm === `/${locale}` || linkNorm === '/') {
    return pathNorm === `/${locale}` || pathNorm === '/';
  }
  return path === linkPath || path.startsWith(linkPath);
}
---

<aside class="sidebar">
  <nav>
    {wikiNav.map((item) =>
      item.children ? (
        <div class="nav-group">
          <span class="nav-group-title">{item.label}</span>
          {item.children.map((child) => {
            const subId = child.id ?? child.label.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
            return child.children ? (
              <details class="nav-subgroup" id={`nav-${subId}`} data-nav-id={subId}>
                <summary class="nav-subgroup-title">
                  <span>{child.label}</span>
                  <span class="nav-group-chevron" aria-hidden="true">▾</span>
                </summary>
                <div class="nav-group-body">
                  {child.children.map((grand) => (
                    <a
                      href={grand.href}
                      class:list={[
                        'nav-item',
                        'nav-child',
                        'nav-child--deep',
                        { 'is-active': isActive(grand.href ?? '') },
                      ]}
                    >
                      {grand.label}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a
                href={child.href}
                class:list={['nav-item', 'nav-child', { 'is-active': isActive(child.href ?? '') }]}
              >
                {child.label}
              </a>
            );
          })}
        </div>
      ) : (
        <a href={item.href} class:list={['nav-item', { 'is-active': isActive(item.href ?? '') }]}>{item.label}</a>
      ),
    )}
  </nav>
</aside>

<script>
  (function () {
    try {
      document.querySelectorAll('.nav-subgroup[data-nav-id]').forEach(function (el) {
        var id = el.getAttribute('data-nav-id');
        if (!id) return;
        var key = 'wiki-nav-' + id + '-open';
        var saved = localStorage.getItem(key);
        if (saved === '0') el.removeAttribute('open');
        else if (saved === '1') el.setAttribute('open', '');
        el.addEventListener('toggle', function () {
          try {
            localStorage.setItem(key, el.open ? '1' : '0');
            window.dispatchEvent(new CustomEvent('wiki-nav-toggle', { detail: { id: id, open: el.open } }));
          } catch (_) {}
        });
      });
    } catch (_) {}
  })();
</script>

<style>
  .sidebar {
    width: var(--wiki-sidebar-w, 192px);
    box-sizing: border-box;
    flex-shrink: 0;
    padding: 0.65rem 0.5rem;
    background: var(--surface);
    overflow-y: auto;
  }
  nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .nav-item {
    padding: 0.3rem 0.4rem;
    border-radius: 4px;
    color: var(--muted);
    font-size: 0.82rem;
    display: block;
  }
  .nav-item:hover { color: var(--accent); background: rgba(51, 123, 250, 0.1); }
  .nav-section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.25rem;
    padding-left: 0.5rem;
  }
  .nav-group-title {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: 0.5rem;
    margin-bottom: 0.15rem;
    padding-left: 0.4rem;
  }
  .nav-subgroup {
    border-radius: 6px;
    margin-top: 0.15rem;
  }
  .nav-subgroup-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    list-style: none;
    cursor: pointer;
    padding: 0.3rem 0.4rem;
    padding-left: 0.75rem;
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: var(--muted);
  }
  .nav-group-chevron {
    font-size: 0.6rem;
    opacity: 0.7;
    transition: transform 0.12s ease;
  }
  .nav-subgroup[open] .nav-group-chevron {
    transform: rotate(180deg);
  }
  .nav-group-body {
    padding-top: 0.1rem;
  }
  .nav-separator {
    border-bottom: 1px solid var(--border);
    margin: 0.3rem 0;
    padding: 0;
  }
  .nav-child { padding-left: 0.75rem !important; }
  .nav-child--deep { padding-left: 1.25rem !important; }
  .nav-item.is-active { color: var(--accent); font-weight: 500; background: rgba(51, 123, 250, 0.12); }
  @media (max-width: 768px) {
    .sidebar { width: 100%; min-height: auto; border-right: none; border-bottom: 1px solid var(--border); }
  }
</style>
