---
import type { Locale } from '../data/i18n';
interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '') || '';
const placeholder = locale === 'ko' ? 'VLA, teleop, diffusion ...' : 'VLA, teleop, diffusion ...';
const ariaLabel = locale === 'ko' ? '검색 (⌘K)' : 'Search (⌘K)';
const closeLabel = locale === 'ko' ? '닫기' : 'Close';
const noIndexMsg = locale === 'ko'
  ? '검색 인덱스 없음. <code>npm run build</code> 후 다시 시도하세요.'
  : 'Search index not found. Run <code>npm run build</code> and try again.';
---

<!-- Inline search trigger (fake input) -->
<button
  type="button"
  id="search-trigger"
  class="search-bar"
  aria-label={ariaLabel}
  title={ariaLabel}
>
  <svg class="search-bar-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.35-4.35"/>
  </svg>
  <span class="search-bar-placeholder">{placeholder}</span>
  <kbd class="search-bar-kbd">⌘K</kbd>
</button>

<!-- Search modal overlay -->
<div id="search-modal" class="search-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label={ariaLabel}>
  <div class="search-modal-backdrop" id="search-modal-backdrop"></div>
  <div class="search-modal-panel">
    <div class="search-modal-header">
      <button type="button" class="search-modal-close" id="search-modal-close" aria-label={closeLabel}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        <kbd class="search-esc-kbd">esc</kbd>
      </button>
    </div>
    <div class="search-modal-inner">
      <div id="search-ui-container"></div>
    </div>
  </div>
</div>

<style>
  /* ── Inline search bar ── */
  .search-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 2rem;
    padding: 0 10px;
    margin-left: 0.75rem;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--muted);
    cursor: pointer;
    font-size: 0.82rem;
    font-family: inherit;
    white-space: nowrap;
    transition: border-color 0.15s, box-shadow 0.15s, color 0.15s;
    min-width: 220px;
    max-width: 380px;
    flex: 1 1 280px;
  }
  .search-bar:hover {
    border-color: var(--accent);
    color: var(--text);
    box-shadow: 0 0 0 2px rgba(51, 123, 250, 0.12);
  }
  .search-bar:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }
  .search-bar-icon {
    flex-shrink: 0;
    opacity: 0.6;
  }
  .search-bar-placeholder {
    flex: 1;
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .search-bar-kbd {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-family: inherit;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 5px;
    line-height: 1.5;
    opacity: 0.7;
  }

  /* ── Modal overlay ── */
  .search-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
    align-items: flex-start;
    justify-content: center;
    padding-top: 72px;
    padding-inline: 16px;
  }
  .search-modal[aria-hidden="false"] {
    display: flex;
  }
  .search-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(3px);
  }
  .search-modal-panel {
    position: relative;
    z-index: 1;
    width: min(660px, 100%);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 100px);
  }
  .search-modal-header {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 8px 12px 0;
    flex-shrink: 0;
  }
  .search-modal-inner {
    overflow-y: auto;
    padding: 8px 16px 16px;
    flex: 1;
  }
  .search-modal-close {
    display: flex;
    align-items: center;
    gap: 5px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 5px 10px;
    font-family: inherit;
    font-size: 0.82rem;
  }
  .search-modal-close:hover {
    color: var(--text);
    background: var(--bg);
  }
  .search-esc-kbd {
    font-size: 0.72rem;
    font-family: inherit;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2px 5px;
  }

  /* ── Pagefind UI theme overrides ── */
  :global(#search-ui-container .pagefind-ui) {
    --pagefind-ui-scale: 0.78;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-font: inherit;
  }
  :global(#search-ui-container .pagefind-ui__search-input) {
    background: var(--bg) !important;
    color: var(--text) !important;
    border-color: var(--border) !important;
  }
  :global(#search-ui-container .pagefind-ui__search-input:focus) {
    border-color: var(--accent) !important;
    box-shadow: 0 0 0 2px rgba(51, 123, 250, 0.15) !important;
    outline: none !important;
  }
  :global(#search-ui-container .pagefind-ui__result) {
    border-color: var(--border) !important;
    padding: 10px 0 !important;
  }
  :global(#search-ui-container .pagefind-ui__result-link) {
    color: var(--accent) !important;
    font-weight: 600 !important;
  }
  :global(#search-ui-container .pagefind-ui__result-excerpt) {
    color: var(--muted) !important;
    font-size: 0.83rem !important;
  }
  :global(#search-ui-container .pagefind-ui__search-clear) {
    background: var(--surface) !important;
    color: var(--muted) !important;
  }
  :global(#search-ui-container .pagefind-ui__message) {
    color: var(--muted) !important;
    font-size: 0.85rem !important;
  }

  /* ── Mobile: hide kbd shortcut hint ── */
  @media (max-width: 768px) {
    .search-bar-kbd { display: none; }
    .search-bar {
      min-width: 120px;
      flex: 1 1 120px;
    }
  }
</style>

<script define:vars={{ base, noIndexMsg }}>
  const trigger = document.getElementById('search-trigger');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-modal-backdrop');
  const closeBtn = document.getElementById('search-modal-close');
  const container = document.getElementById('search-ui-container');

  let initialized = false;

  async function initPagefind() {
    if (initialized) return;
    initialized = true;
    try {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = `${base}/pagefind/pagefind-ui.css`;
      document.head.appendChild(link);

      await new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = `${base}/pagefind/pagefind-ui.js`;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });

      new window.PagefindUI({
        element: '#search-ui-container',
        showImages: false,
        showEmptyFilters: false,
        resetStyles: false,
        baseUrl: base || '/',
      });
    } catch (_) {
      container.innerHTML = `<p style="padding:12px 4px;color:var(--muted);font-size:0.85rem;">${noIndexMsg}</p>`;
    }
  }

  function focusInput() {
    setTimeout(() => {
      const input = container.querySelector('input[type="text"],input[type="search"]');
      if (input) input.focus();
    }, 60);
  }

  function openModal() {
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    initPagefind().then(focusInput);
  }

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    trigger.focus();
  }

  trigger.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      modal.getAttribute('aria-hidden') === 'false' ? closeModal() : openModal();
    }
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
      closeModal();
    }
  });
</script>
