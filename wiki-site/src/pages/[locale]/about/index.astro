c-1.139-.875-1.563-2.317-1.563-3.203 0-.334.109-.457.305-.454"/></svg>`;
const svgInstagram = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077"/></svg>`;

function linkIcon(type: string) {
  if (type === 'linkedin') return svgLinkedIn;
  if (type === 'github') return svgGitHub;
  if (type === 'huggingface') return svgHF;
  if (type === 'instagram') return svgInstagram;
  return '';
}
function linkLabel(type: string) {
  if (type === 'linkedin') return 'LinkedIn';
  if (type === 'github') return 'GitHub';
  if (type === 'huggingface') return 'Hugging Face';
  if (type === 'instagram') return 'Instagram';
  return type;
}
---

<WikiLayout title={t.about.title} locale={locale}>
  <article class="about-page">

    <!-- Company header -->
    <div class="company-header">
      <div class="company-logo-wrap">
        <img src={`${base}/images/config-logo.png`} alt="Config Intelligence" class="company-logo" width="56" height="56" onerror="this.style.display='none'" />
      </div>
      <div class="company-info">
        <h1 class="company-name">Config Intelligence Inc.</h1>
        <p class="company-mission">{t.about.mission}</p>
        <p class="company-location">Seoul, Korea</p>
      </div>
    </div>

    <!-- Team section -->
    <section class="team-section">
      <h2 class="team-heading">{t.about.team}</h2>
      <div class="team-grid">
        {members.map((member) => (
          <button
            class="member-card"
            data-member={member.id}
            aria-haspopup="dialog"
            aria-label={locale === 'ko' ? `${member.nameKo} 상세 보기` : `View ${member.name} details`}
          >
            <img
              src={`${base}${member.photo}`}
              alt={member.name}
              class="member-photo"
              width="80"
              height="80"
              onerror="this.style.display='none'"
            />
            <div class="member-info">
              <span class="member-name">{locale === 'ko' ? member.nameKo : member.name}</span>
              <span class="member-title">{member.title}</span>
              <span class="member-intro">{locale === 'ko' ? member.introKo : member.intro}</span>
            </div>
          </button>
        ))}
      </div>
    </section>

    <!-- Modals -->
    {members.map((member) => (
      <dialog class="member-modal" id={`modal-${member.id}`} aria-label={member.name}>
        <div class="modal-inner">
          <button class="modal-close" aria-label="Close">&times;</button>
          <div class="modal-header">
            <img
              src={`${base}${member.photo}`}
              alt={member.name}
              class="modal-photo"
              width="96"
              height="96"
              onerror="this.style.display='none'"
            />
            <div class="modal-header-info">
              <h2 class="modal-name">{locale === 'ko' ? member.nameKo : member.name}</h2>
              <p class="modal-title">{member.title}</p>
              <div class="modal-links">
                {Object.entries(member.links).map(([type, url]) => (
                  <a
                    href={url}
                    target="_blank"
                    rel="noreferrer"
                    class="about-link"
                    aria-label={linkLabel(type)}
                    set:html={linkIcon(type)}
                  />
                ))}
              </div>
            </div>
          </div>

          <div class="modal-body">
            <section class="modal-section">
              <h3>{t.about.education}</h3>
              <ul>
                {member.education.map((edu) => (
                  <li>
                    <strong>{locale === 'ko' && edu.schoolEn ? edu.school : (edu.schoolEn ?? edu.school)}</strong>
                    {' — '}
                    {locale === 'ko' ? edu.degreeKo : edu.degree}
                  </li>
                ))}
              </ul>
            </section>

            <section class="modal-section">
              <h3>
                {t.about.experience}
                <span class="modal-exp-total">
                  · {locale === 'ko' ? member.totalExperienceKo : member.totalExperience}
                </span>
              </h3>
              <ul>
                {member.experience.map((exp) => (
                  <li>
                    <strong>{exp.period}</strong> · <strong>{exp.company}</strong> — {exp.role}
                    {exp.desc && locale !== 'ko' ? ` · ${exp.desc}` : ''}
                    {exp.descKo && locale === 'ko' ? ` · ${exp.descKo}` : ''}
                  </li>
                ))}
              </ul>
            </section>

            <section class="modal-section">
              <h3>{t.about.focus}</h3>
              <p>{locale === 'ko' ? member.focusKo : member.focus}</p>
            </section>
          </div>
        </div>
      </dialog>
    ))}

  </article>
</WikiLayout>

<script>
  // Open modal on card click
  document.querySelectorAll<HTMLButtonElement>('.member-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.member;
      const modal = document.getElementById(`modal-${id}`) as HTMLDialogElement | null;
      if (modal) modal.showModal();
    });
  });

  // Close modal on X button
  document.querySelectorAll<HTMLButtonElement>('.modal-close').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modal = btn.closest('dialog') as HTMLDialogElement | null;
      if (modal) modal.close();
    });
  });

  // Close modal on backdrop click
  document.querySelectorAll<HTMLDialogElement>('.member-modal').forEach((modal) => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  });
</script>

<style>
  .about-page { max-width: 720px; padding: 0 1rem 3rem; }

  /* Company header */
  .company-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
    margin-bottom: 2.5rem;
  }
  .company-logo-wrap { flex-shrink: 0; }
  .company-logo {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    object-fit: contain;
  }
  .company-name {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 0.35rem 0;
  }
  .company-mission {
    color: var(--muted);
    margin: 0 0 0.25rem 0;
    font-size: 0.97rem;
    line-height: 1.55;
  }
  .company-location {
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0;
  }

  /* Team section */
  .team-heading {
    font-size: 1.05rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.85rem;
  }

  /* Member card */
  .member-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    background: var(--surface);
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: border-color 0.12s, box-shadow 0.12s;
    color: var(--text);
    font: inherit;
  }
  .member-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(51, 123, 250, 0.1);
  }
  .member-photo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
  }
  .member-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .member-name { font-weight: 700; font-size: 1rem; }
  .member-title { font-size: 0.85rem; color: var(--muted); }
  .member-intro { font-size: 0.85rem; color: var(--muted); line-height: 1.45; margin-top: 0.1rem; }

  /* Modal */
  .member-modal {
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--bg);
    color: var(--text);
    padding: 0;
    max-width: 600px;
    width: calc(100vw - 2rem);
    max-height: calc(100vh - 4rem);
    overflow: hidden;
  }
  .member-modal::backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
  }
  .modal-inner {
    overflow-y: auto;
    max-height: calc(100vh - 4rem);
    padding: 1.5rem;
    position: relative;
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .modal-close:hover { background: var(--border); }

  .modal-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .modal-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
  }
  .modal-name { font-size: 1.35rem; font-weight: 700; margin: 0 0 0.2rem 0; }
  .modal-title { font-size: 0.9rem; color: var(--muted); margin: 0 0 0.65rem 0; }
  .modal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Social link buttons (shared between card and modal) */
  .about-link {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--social-btn-bg, var(--surface));
    color: var(--social-btn-fg, var(--muted));
    text-decoration: none;
    border: 1px solid var(--border);
  }
  .about-link:hover {
    background: rgba(37, 99, 235, 0.9);
    color: #fff;
    text-decoration: none;
  }
  .about-link svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
    display: block;
  }

  /* Modal body */
  .modal-body { display: flex; flex-direction: column; gap: 1.25rem; }
  .modal-section h3 {
    font-size: 1rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.25rem;
    margin: 0 0 0.5rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    align-items: baseline;
  }
  .modal-exp-total { font-size: 0.8rem; font-weight: 400; color: var(--muted); }
  .modal-section ul { margin: 0; padding-left: 1.2rem; }
  .modal-section li { margin-bottom: 0.45rem; line-height: 1.5; font-size: 0.93rem; }
  .modal-section p { margin: 0; font-size: 0.93rem; color: var(--muted); line-height: 1.6; }

  @media (max-width: 480px) {
    .company-header { flex-direction: column; gap: 0.85rem; }
    .modal-header { flex-direction: column; gap: 0.75rem; }
  }
</style>
