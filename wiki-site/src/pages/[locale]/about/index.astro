6 10.354c.824-1.19.766-2.082-.365-3.194-1.13-1.112-1.789-2.738-1.789-2.738s-.246-.945-.806-.858-.97 1.499.202 2.362c1.173.864-.233 1.45-.685.64-.45-.812-1.683-2.896-2.322-3.295s-1.089-.175-.938.647 2.822 2.813 2.562 3.244-1.176-.506-1.176-.506-2.866-2.567-3.49-1.898.473 1.23 2.037 2.16c1.564.932 1.686 1.178 1.464 1.53s-3.675-2.511-4-1.297c-.323 1.214 3.524 1.567 3.287 2.405-.238.839-2.71-1.587-3.216-.642-.506.946 3.49 2.056 3.522 2.064 1.29.33 4.568 1.028 5.713-.624m5.349 0c-.824-1.19-.766-2.082.365-3.194 1.13-1.112 1.789-2.738 1.789-2.738s.246-.945.806-.858.97 1.499-.202 2.362c-1.173.864.233 1.45.685.64.451-.812 1.683-2.896 2.322-3.295s1.089-.175.938.647-2.822 2.813-2.562 3.244 1.176-.506 1.176-.506 2.866-2.567 3.49-1.898-.473 1.23-2.037 2.16c-1.564.932-1.686 1.178-1.464 1.53s3.675-2.511 4-1.297c.323 1.214-3.524 1.567-3.287 2.405.238.839 2.71-1.587 3.216-.642.506.946-3.49 2.056-3.522 2.064-1.29.33-4.568 1.028-5.713-.624"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/kwangc" target="_blank" rel="noreferrer" class="about-link" aria-label="Instagram">
            <svg class="about-link-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077"
              />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <section class="about-section">
      <h2>{t.about.education}</h2>
      <ul class="about-edu-list">
        <li>
          <strong>University of California, Berkeley</strong> — {t.about.degree}
        </li>
        <li>
          <strong>{t.about.highSchool}</strong> — {t.about.highSchoolMajor}
        </li>
      </ul>
    </section>

    <section class="about-section">
      <h2>
        {t.about.experience}
        <span class="about-exp-total">· {t.about.totalExperience}</span>
      </h2>
      <ul>
        <li><strong>2026.04.~</strong> · <strong>Config Intelligence Inc.</strong> — Head of Product. Data infrastructure & foundation models for general-purpose bimanual robotics.</li>
        <li><strong>2022.02.~2026.04.</strong> · <strong>Toss</strong> — Platform Product Owner</li>
        <li><strong>2021.03.~2022.01.</strong> · <strong>Tridge</strong> — Senior Product Manager</li>
        <li><strong>2018.07.~2021.03.</strong> · <strong>Lineable</strong> — COO & CTO</li>
        <li><strong>2014.07.~2016.11.</strong> · <strong>Samsung E&A</strong> — Process Engineer</li>
      </ul>
    </section>

    <section class="about-section">
      <h2>{t.about.focus}</h2>
      <p>{t.about.focusDesc}</p>
    </section>
  </article>
</WikiLayout>

<style>
  .about-page { max-width: 640px; padding: 0 1rem 3rem; }
  .about-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .about-photo {
    width: 160px;
    height: 160px;
    object-fit: cover;
    object-position: top;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .about-intro h1 { font-size: 1.75rem; margin: 0 0 0.5rem 0; }
  .about-role { color: var(--muted); margin: 0; font-size: 1rem; }
  .about-links {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .about-link {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 23, 42, 0.9);
    color: #e5e7eb;
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.35);
  }
  .about-link:hover {
    background: rgba(37, 99, 235, 0.95);
    color: #fff;
    text-decoration: none;
  }
  .about-link-icon {
    width: 18px;
    height: 18px;
    display: block;
    fill: currentColor;
  }
  .about-section { margin-top: 1.5rem; }
  .about-section h2 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.5rem;
    align-items: baseline;
  }
  .about-section ul { margin: 0.5rem 0 0; padding-left: 1.25rem; }
  .about-section li { margin-bottom: 0.5rem; line-height: 1.5; }
  .about-edu-list {
    list-style: disc;
  }
  .about-exp-total {
    font-size: 0.85rem;
    color: var(--muted);
    font-weight: 400;
  }
</style>
