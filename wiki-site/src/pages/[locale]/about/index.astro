---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { i18n } from '../../../data/i18n';
import type { Locale } from '../../../data/i18n';
import teamData from '../../../data/team.json';

export async function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'ko' } }];
}

const { locale } = Astro.params as { locale: Locale };
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const t = i18n[locale] ?? i18n.en;
const members = teamData.members;

const svgLinkedIn = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5C4.98 4.88 3.9 6 2.5 6S0 4.88 0 3.5 1.08 1 2.5 1s2.48 1.12 2.48 2.5zM.32 8.16h4.36V24H.32V8.16zM8.34 8.16h4.18v2.16h.06c.58-1.1 2-2.26 4.12-2.26 4.4 0 5.21 2.9 5.21 6.68V24h-4.36v-8.02c0-1.92-.04-4.4-2.68-4.4-2.68 0-3.09 2.09-3.09 4.26V24H8.34V8.16z"/></svg>`;
