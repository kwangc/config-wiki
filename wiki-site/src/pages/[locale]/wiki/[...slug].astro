---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '../../../data/i18n';
import wikiLastModified from '../../../data/wiki-last-modified.json';

export async function getStaticPaths() {
  const entries = await getCollection('wiki');
  const paths: { params: { locale: string; slug: string | string[] } }[] = [];
  for (const e of entries) {
    if (!e.id.includes('/')) continue;
    const [locale, ...parts] = e.id.split('/');
    if (locale !== 'en' && locale !== 'ko') continue;
    let slug = parts.join('/');
    // Strip .md extension for clean URLs (no .md in browser address bar)
    if (slug.endsWith('.md')) slug = slug.slice(0, -3);
    // Serve README at parent directory URL so ./sibling links resolve correctly
    if (slug.includes('/') && slug.endsWith('/README')) {
      slug = slug.slice(0, -'/README'.length);
    }
    paths.push({ params: { locale, slug } });
  }
  return paths;
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string | string[] };
const slugStr = typeof slug === 'string' ? slug : (Array.isArray(slug) ? slug.join('/') : '');
const id = `${locale}/${slugStr}`;
const entries = await getCollection('wiki');
const entry = entries.find((e) => e.id === id)
  ?? entries.find((e) => e.id === `${id}.md`)
  ?? entries.find((e) => e.id === `${id}/README.md`);
if (!entry) return Astro.redirect(import.meta.env.BASE_URL.replace(/\/$/, '') + '/' + locale + '/');

const { Content, headings } = await entry.render();
const h1 = headings.find((h) => h.depth === 1)?.text;
const title = h1 ?? (entry.data as { title?: string }).title ?? slugStr.split('/').pop() ?? 'Wiki';
const lastModifiedMap = wikiLastModified as Record<string, string>;
const lastEdited = lastModifiedMap[entry.id] ?? new Date().toISOString().slice(0, 10);
---

<WikiLayout title={title} locale={locale}>
  <div class="content-with-toc">
    <article class="wiki-article" data-pagefind-body>
      <Content />
    </article>
    <TableOfContents headings={headings} lastEdited={lastEdited} />
  </div>
</WikiLayout>

<style>
  .content-with-toc {
    display: flex;
    gap: 2rem;
    width: 100%;
    align-items: flex-start;
  }
  .wiki-article {
    flex: 1;
    min-width: 0;
    max-width: 720px;
    padding: 0 1rem 3rem;
  }
  .wiki-article :global(h1) { font-size: 1.75rem; margin-top: 0; }
  .wiki-article :global(h2) { font-size: 1.25rem; margin-top: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; scroll-margin-top: 4rem; }
  .wiki-article :global(h3) { font-size: 1.05rem; margin-top: 1rem; scroll-margin-top: 4rem; }
  .wiki-article :global(h4) { scroll-margin-top: 4rem; }
  .wiki-article :global(table) { border-collapse: collapse; width: 100%; }
  .wiki-article :global(th), .wiki-article :global(td) { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
  .wiki-article :global(blockquote) { margin: 1rem 0; padding-left: 1rem; border-left: 4px solid var(--accent); color: var(--muted); }
  .wiki-article :global(code) { background: var(--surface); padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .wiki-article :global(pre) { background: var(--surface); padding: 1rem; border-radius: 8px; overflow-x: auto; }
  .wiki-article :global(pre code) { padding: 0; background: none; }
</style>
